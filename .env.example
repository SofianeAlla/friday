# Friday picks up these keys on first launch and pre-fills the matching provider.
# You can also paste keys directly in Settings → Providers (stored locally in
# server/.friday/config.json, which is gitignored). Nothing leaves your machine
# except the calls you make to the model providers you configure.

# Anthropic Claude (API)
ANTHROPIC_API_KEY=

# OpenAI / Codex (API)
OPENAI_API_KEY=

# Mistral Code (OpenAI-compatible API)
MISTRAL_API_KEY=

# Google Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY=

# Qwen via DashScope (OpenAI-compatible). Or run Qwen locally with Ollama (no key).
DASHSCOPE_API_KEY=

# Where Friday opens by default. Defaults to your home directory if unset.
FRIDAY_WORKDIR=

# Backend port (frontend dev server proxies /api here).
PORT=8787
